{{ header }}{{ column_left }}
<div id="content">
  <div class="page-header"><div class="container-fluid">
    <div class="pull-right">
      <button id="sx-save" class="btn btn-primary"><i class="fa fa-save"></i> {{ button_save }}</button>
      <a href="{{ cancel }}" class="btn btn-default">{{ button_cancel }}</a>
    </div>
    <h1>{{ heading_title }} — {{ text_binding_edit }}</h1>
  </div></div>
  <div class="container-fluid">
    <div id="sx-alert"></div>
    <div class="panel panel-default"><div class="panel-body">
      <form class="form-horizontal">
        <input type="hidden" id="f-binding_id" value="{{ binding.binding_id | default('') }}">

        <div class="form-group">
          <label class="col-sm-3 control-label">{{ entry_entity }}</label>
          <div class="col-sm-6"><select id="f-entity_type" class="form-control">
            <option value="product">product</option>
            <option value="category">category</option>
            <option value="information">information</option>
            <option value="manufacturer">manufacturer (SEO URL only)</option>
          </select></div>
        </div>

        <div class="form-group">
          <label class="col-sm-3 control-label">{{ entry_target_kind }}</label>
          <div class="col-sm-6"><select id="f-target_kind" class="form-control">
            <option value="description_column">description column</option>
            <option value="seo_keyword">seo_keyword (SEO URL)</option>
            <option value="eav_attribute">eav_attribute (product attribute)</option>
          </select></div>
        </div>

        <div class="form-group" id="grp-target_column">
          <label class="col-sm-3 control-label">{{ entry_target_field }}</label>
          <div class="col-sm-6"><select id="f-target_column" class="form-control"></select>
            <span class="help-block">{{ help_target }}</span></div>
        </div>

        <div class="form-group" id="grp-seo_disambiguate" style="display:none">
          <label class="col-sm-3 control-label">{{ entry_seo_disambiguate }}</label>
          <div class="col-sm-6"><label class="checkbox-inline"><input type="checkbox" id="f-seo_disambiguate"> {{ text_seo_disambiguate }}</label>
            <span class="help-block">{{ help_seo_disambiguate }}</span></div>
        </div>

        <div class="form-group" id="grp-store_scope" style="display:none">
          <label class="col-sm-3 control-label">{{ entry_store_scope }}</label>
          <div class="col-sm-6"><input type="text" id="f-store_scope" class="form-control" value="ALL">
            <span class="help-block">{{ help_store_scope }}</span></div>
        </div>

        <div class="form-group" id="grp-attribute" style="display:none">
          <label class="col-sm-3 control-label">{{ entry_attribute }}</label>
          <div class="col-sm-6"><select id="f-attribute_id" class="form-control">
            {% for a in attributes %}<option value="{{ a.value }}">{{ a.label }}</option>{% endfor %}
          </select><span class="help-block">{{ help_attribute }}</span></div>
        </div>

        <div class="form-group">
          <label class="col-sm-3 control-label">{{ entry_source_mode }}</label>
          <div class="col-sm-6"><select id="f-source_mode" class="form-control">
            <option value="template">{{ text_mode_template }}</option>
            <option value="per_entity">{{ text_mode_per_entity }}</option>
          </select><span class="help-block">{{ help_source_mode }}</span></div>
        </div>

        <div class="form-group">
          <label class="col-sm-3 control-label">{{ entry_source }}</label>
          <div class="col-sm-6"><select id="f-template_id" class="form-control">
            {% for t in templates %}<option value="{{ t.template_id }}">{{ t.name }}</option>{% endfor %}
          </select><span class="help-block">{{ help_template_fallback }}</span></div>
        </div>

        <div class="form-group">
          <label class="col-sm-3 control-label">{{ entry_mode }}</label>
          <div class="col-sm-6">
            <label class="radio-inline"><input type="radio" name="mode" value="seed" checked> {{ text_mode_seed }}</label>
            <label class="radio-inline"><input type="radio" name="mode" value="regenerate"> {{ text_mode_regen }}</label>
          </div>
        </div>
        <div class="form-group">
          <label class="col-sm-3 control-label">{{ entry_flags }}</label>
          <div class="col-sm-6">
            <div class="checkbox"><label><input type="checkbox" id="f-preserve" checked> {{ text_preserve }}</label></div>
            <div class="checkbox"><label><input type="checkbox" id="f-clear"> {{ text_clear }}</label></div>
            <p class="help-block">{{ help_required_guard }}</p>
          </div>
        </div>
        <div class="form-group">
          <label class="col-sm-3 control-label">{{ entry_trigger }}</label>
          <div class="col-sm-6"><div class="checkbox"><label><input type="checkbox" id="f-trigger"> {{ text_trigger_save }}</label></div>
            <p class="help-block">{{ help_trigger }}</p></div>
        </div>
        <div class="form-group">
          <label class="col-sm-3 control-label">{{ entry_cadence }}</label>
          <div class="col-sm-6"><select id="f-cadence" class="form-control">
            <option value="off">{{ text_cadence_off }}</option>
            <option value="auto">{{ text_cadence_auto }}</option>
          </select><span class="help-block">{{ help_cadence }}</span></div>
        </div>
        <div class="form-group">
          <label class="col-sm-3 control-label">{{ entry_active }}</label>
          <div class="col-sm-6"><div class="checkbox"><label><input type="checkbox" id="f-status"> {{ text_enabled }}</label></div></div>
        </div>
      </form>
    </div></div>
  </div>
</div>

<script type="text/javascript">
var SX = {{ config_json|raw }};
var SX_BINDING = {{ binding_json|raw }};
(function($){
  function post(url, data){ return $.ajax({url:url, type:'post', dataType:'json', data:data}); }
  function loadTargets(sel){
    post(SX.endpoints.targets, {entity_type:$('#f-entity_type').val()}).done(function(list){
      var h=''; $.each(list, function(i,o){ h += '<option value="'+o.value+'">'+o.label+'</option>'; });
      $('#f-target_column').html(h); if(sel){ $('#f-target_column').val(sel); }
    });
  }
  // Per-entity authoring UI is product-only for now — disable it elsewhere.
  function syncSourceMode(){
    var isProduct = $('#f-entity_type').val() === 'product';
    $('#f-source_mode option[value=per_entity]').prop('disabled', !isProduct);
    if(!isProduct && $('#f-source_mode').val() === 'per_entity'){ $('#f-source_mode').val('template'); }
  }
  // seo_keyword has no column (target = the entity's SEO URL keyword); it exposes
  // the disambiguation toggle instead.
  function syncTargetKind(){
    var kind = $('#f-target_kind').val();
    var isSeo = kind === 'seo_keyword', isEav = kind === 'eav_attribute';
    $('#grp-target_column').toggle(!isSeo && !isEav);
    $('#grp-seo_disambiguate').toggle(isSeo);
    $('#grp-store_scope').toggle(isSeo);
    $('#grp-attribute').toggle(isEav);
  }
  // Manufacturer = seo_keyword only; eav_attribute (product attributes) = product only.
  function syncEntityCaps(){
    var e = $('#f-entity_type').val();
    var isMfr = e === 'manufacturer', isProduct = e === 'product';
    $('#f-target_kind option[value=description_column]').prop('disabled', isMfr);
    $('#f-target_kind option[value=eav_attribute]').prop('disabled', !isProduct);
    if(isMfr){ $('#f-target_kind').val('seo_keyword'); }
    if(!isProduct && $('#f-target_kind').val() === 'eav_attribute'){ $('#f-target_kind').val('description_column'); }
    syncTargetKind();
  }
  $('#f-entity_type').on('change', function(){ loadTargets(); syncSourceMode(); syncEntityCaps(); });
  $('#f-target_kind').on('change', syncTargetKind);

  // Prefill on edit
  if(SX_BINDING){
    $('#f-entity_type').val(SX_BINDING.entity_type);
    $('#f-target_kind').val(SX_BINDING.target_kind || 'description_column');
    $('#f-source_mode').val(SX_BINDING.source_mode || 'template');
    $('#f-template_id').val(SX_BINDING.template_id);
    $('input[name=mode]').filter('[value='+(SX_BINDING.regenerate_on_save=='1'?'regenerate':'seed')+']').prop('checked',true);
    $('#f-preserve').prop('checked', SX_BINDING.preserve_manual_edits=='1');
    $('#f-clear').prop('checked', SX_BINDING.clear_on_empty=='1');
    $('#f-trigger').prop('checked', SX_BINDING.trigger_on_save=='1');
    $('#f-cadence').val(SX_BINDING.cadence || 'off');
    $('#f-status').prop('checked', SX_BINDING.status=='1');
    $('#f-seo_disambiguate').prop('checked', SX_BINDING.seo_disambiguate=='1');
    $('#f-store_scope').val(SX_BINDING.store_scope || 'ALL');
    $('#f-attribute_id').val(SX_BINDING.attribute_id || 0);
    loadTargets(SX_BINDING.target_column);
    syncSourceMode(); syncEntityCaps();
  } else { loadTargets(); syncSourceMode(); syncEntityCaps(); }

  $('#sx-save').on('click', function(){
    var regen = $('input[name=mode]:checked').val()==='regenerate';
    var data = {
      binding_id: $('#f-binding_id').val(),
      entity_type: $('#f-entity_type').val(),
      target_kind: $('#f-target_kind').val(),
      target_column: ($('#f-target_kind').val()==='description_column') ? $('#f-target_column').val() : '',
      attribute_id: $('#f-target_kind').val()==='eav_attribute' ? ($('#f-attribute_id').val()||0) : 0,
      source_mode: $('#f-source_mode').val(),
      template_id: $('#f-template_id').val(),
      trigger_on_save: $('#f-trigger').is(':checked') ? 1 : 0,
      cadence: $('#f-cadence').val() || 'off',
      auto_seed_empty: regen ? 0 : 1,
      regenerate_on_save: regen ? 1 : 0,
      preserve_manual_edits: $('#f-preserve').is(':checked') ? 1 : 0,
      clear_on_empty: $('#f-clear').is(':checked') ? 1 : 0,
      seo_disambiguate: $('#f-seo_disambiguate').is(':checked') ? 1 : 0,
      store_scope: $('#f-store_scope').val() || 'ALL',
      status: $('#f-status').is(':checked') ? 1 : 0
    };
    post(SX.endpoints.save, data).done(function(r){
      if(r.errors){
        var m=''; for(var k in r.errors){ m += '<li>'+k+': '+r.errors[k]+'</li>'; }
        $('#sx-alert').html('<div class="alert alert-danger"><ul>'+m+'</ul></div>');
      } else { location.href='{{ cancel }}'; }
    });
  });
})(jQuery);
</script>
{{ footer }}
